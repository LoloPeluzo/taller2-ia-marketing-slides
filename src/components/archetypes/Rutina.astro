---
import SlideFrame from '../SlideFrame.astro';

interface Props {
  num: string;
  kicker: string;
  title: string;
  hours: string;
  hoursSubtitle: string;
  footerHighlight: string;
  steps: {
    day: string;
    accent: 'blue' | 'red';
    tasks: { t: string; d: string }[];
  }[];
}

const { num, kicker, title, hours, hoursSubtitle, footerHighlight, steps } = Astro.props;
---

<SlideFrame num={num} kicker={kicker}>
  <style>
    @keyframes slideIn { 
      from { opacity: 0; transform: translateX(-2.4cqw); } 
      to { opacity: 1; transform: none; } 
    }
    .animate-slide-in {
      animation: slideIn 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }
  </style>

  <div class="flex items-end justify-between gap-[4cqw] animate-rise-in">
    <div>
      <h1 class="font-display font-bold text-[6.2cqh] leading-none tracking-[-0.02em] m-0 text-brand-blue">{title}</h1>
    </div>
    <div class="flex flex-col items-end bg-brand-blue rounded-[1.3cqh] px-[2cqw] py-[1.6cqh]">
      <span class="font-display font-bold text-[3.6cqh] leading-none text-white">{hours}</span>
      <span class="font-body text-[1.5cqh] text-[#bcd0ea] mt-[0.4cqh] tracking-[0.04em]">{hoursSubtitle}</span>
    </div>
  </div>

  <div class="relative z-10 flex-1 flex flex-col justify-center my-[3cqh]">
   <div class="relative flex flex-col gap-[2.4cqh]">
    <div class="absolute left-[1.95cqw] top-[1.4cqh] bottom-[1.4cqh] w-[2px] bg-[#dde1e8] z-0"></div>
    
    {steps.map((s, i) => (
      <div class="relative z-10 grid grid-cols-[4cqw_16cqw_1fr] items-start gap-[2cqw] animate-slide-in" style={`animation-delay: ${0.12 + i * 0.1}s`}>
        <div class="flex justify-center pt-[0.4cqh]">
          <span class={`w-[1.9cqh] h-[1.9cqh] rounded-full shadow-[0_0_0_0.6cqh_#f3f4f6,0_0_0_0.75cqh_${s.accent === 'red' ? 'var(--color-brand-red)' : 'var(--color-brand-blue)'}] block ${s.accent === 'red' ? 'bg-brand-red' : 'bg-brand-blue'}`}></span>
        </div>
        <div class={`font-display font-bold text-[2.7cqh] leading-[1.1] ${s.accent === 'red' ? 'text-brand-red' : 'text-brand-blue'}`}>
          {s.day}
        </div>
        <div class="flex flex-col gap-[1.1cqh]">
          {s.tasks.map(t => (
            <div class="flex items-center justify-between gap-[2cqw] border-b border-[#e8eaee] pb-[1.1cqh]">
              <span class="font-body text-[2.15cqh] text-ink">{t.t}</span>
              <span class={`flex-none font-display font-bold text-[2.2cqh] rounded-[0.9cqh] px-[1.3cqw] py-[0.7cqh] ${s.accent === 'red' ? 'text-brand-red bg-brand-red/10' : 'text-brand-blue bg-brand-blue/10'}`}>
                {t.d}
              </span>
            </div>
          ))}
        </div>
      </div>
    ))}
   </div>
  </div>

  <div class="relative z-10 flex items-center gap-[1.6cqw] animate-rise-in" style="animation-delay: 0.55s">
    <span class="font-display font-bold text-[2.5cqh] text-ink" set:html={footerHighlight}></span>
  </div>
</SlideFrame>
