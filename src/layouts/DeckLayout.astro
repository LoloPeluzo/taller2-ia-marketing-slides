---
import '../styles/global.css';

interface Props {
  title?: string;
  moduleName?: string;
  themeName?: string;
  currentSlideNum: number;
  totalSlides: number;
  prevUrl?: string;
  nextUrl?: string;
}

const { 
  title = "Taller IA Marketing", 
  moduleName = "Estrategia", 
  themeName = "Pilares", 
  currentSlideNum, 
  totalSlides,
  prevUrl,
  nextUrl
} = Astro.props;

const numStr = String(currentSlideNum).padStart(2, '0');
const totalStr = String(totalSlides).padStart(2, '0');
---

<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} - {moduleName}</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body class="m-0 p-0 h-full bg-canvas text-ink font-body overflow-hidden">

  <div class="flex w-full h-[100dvh] overflow-hidden bg-canvas">

    <!-- Sidebar -->
    <aside id="sidebar" class="flex-none bg-brand-sidebar text-white overflow-hidden relative z-10 transition-[width] duration-300 ease-in-out" style="width: 280px;">
      
      <!-- Expanded State -->
      <div id="sidebar-expanded" class="w-[280px] h-full flex flex-col">
        <a href="/" class="flex items-center gap-[14px] p-[22px_20px] bg-transparent border-b border-white/10 hover:bg-white/5 transition-colors no-underline">
          <span class="flex-none w-[40px] h-[40px] rounded-[11px] bg-brand-red flex items-center justify-center font-display font-bold text-[17px] text-white">ia</span>
          <span class="flex flex-col">
            <span class="font-display font-bold text-[16px] text-white tracking-[-0.01em]">Taller IA</span>
            <span class="font-body text-[12.5px] text-sidebar-gray-1">Marketing con IA</span>
          </span>
        </a>

        <nav class="flex-1 overflow-y-auto p-[14px_12px] flex flex-col gap-[3px]">
          <div class="p-[10px_10px_6px] font-display font-bold text-[10.5px] tracking-[0.18em] text-[#5f80ab] uppercase">Programa</div>

          <!-- Contexto -->
          <div class="flex items-center gap-[12px] p-[11px_10px] rounded-[10px] cursor-not-allowed text-sidebar-gray-2 opacity-70">
            <span class="flex-none w-[26px] h-[26px] rounded-[7px] border-[1.5px] border-white/20 flex items-center justify-center font-display font-bold text-[11px] text-sidebar-gray-1">00</span>
            <span class="flex-1 font-display font-semibold text-[14.5px]">Contexto</span>
            <span class="font-body text-[11.5px] text-sidebar-gray-3">8/8</span>
          </div>

          <!-- Estrategia (Active) -->
          <div class="mt-[2px] rounded-[12px] bg-white/5 p-[4px]">
            <div class="flex items-center gap-[12px] p-[9px_8px]">
              <span class="flex-none w-[26px] h-[26px] rounded-[7px] bg-brand-red flex items-center justify-center font-display font-bold text-[11px] text-white">01</span>
              <span class="flex-1 font-display font-bold text-[14.5px] text-white">Estrategia</span>
              <span class="font-body text-[11.5px] text-sidebar-gray-1">en curso</span>
            </div>
            <div class="flex flex-col gap-[2px] p-[2px_2px_4px]">
              <a href="/estrategia/1" class="flex flex-col gap-[8px] p-[10px_12px] rounded-[9px] bg-white/10 border-l-[3px] border-brand-red text-left no-underline">
                <div class="flex items-center justify-between">
                  <span class="font-display font-semibold text-[13.5px] text-white">Pilares</span>
                  <span class="font-body text-[11.5px] text-[#cdd9e8]">4/10</span>
                </div>
                <div class="h-[4px] rounded-[4px] bg-white/20 overflow-hidden"><div class="w-[40%] h-full bg-brand-red rounded-[4px]"></div></div>
              </a>
              <a href="/estrategia/11" class="flex flex-col gap-[8px] p-[10px_12px] rounded-[9px] hover:bg-white/5 text-left no-underline">
                <div class="flex items-center justify-between">
                  <span class="font-display font-semibold text-[13.5px] text-[#cfdbeb]">Calendario</span>
                  <span class="font-body text-[11.5px] text-[#8aa3c6]">0/6</span>
                </div>
                <div class="h-[4px] rounded-[4px] bg-white/10 overflow-hidden"><div class="w-[2%] h-full bg-sidebar-gray-3 rounded-[4px]"></div></div>
              </a>
            </div>
          </div>

          <!-- Creación -->
          <div class="flex items-center gap-[12px] p-[11px_10px] rounded-[10px] cursor-not-allowed text-sidebar-gray-2 mt-[2px] opacity-70">
            <span class="flex-none w-[26px] h-[26px] rounded-[7px] border-[1.5px] border-white/20 flex items-center justify-center font-display font-bold text-[11px] text-sidebar-gray-1">02</span>
            <span class="flex-1 font-display font-semibold text-[14.5px]">Creación</span>
            <span class="font-body text-[11.5px] text-sidebar-gray-3">0/9</span>
          </div>
          
          <!-- Ejecución -->
          <div class="flex items-center gap-[12px] p-[11px_10px] rounded-[10px] cursor-not-allowed text-sidebar-gray-2 opacity-70">
            <span class="flex-none w-[26px] h-[26px] rounded-[7px] border-[1.5px] border-white/20 flex items-center justify-center font-display font-bold text-[11px] text-sidebar-gray-1">03</span>
            <span class="flex-1 font-display font-semibold text-[14.5px]">Ejecución</span>
            <span class="font-body text-[11.5px] text-sidebar-gray-3">0/7</span>
          </div>

        </nav>
      </div>

      <!-- Collapsed State -->
      <div id="sidebar-collapsed" class="hidden w-[78px] h-full flex flex-col items-center p-[18px_0] gap-[9px]">
        <a href="/" class="w-[42px] h-[42px] rounded-[11px] bg-brand-red flex items-center justify-center font-display font-bold text-[17px] text-white no-underline">ia</a>
        <div class="w-[32px] h-[1px] bg-white/10 my-[10px]"></div>
        <div class="w-[40px] h-[40px] rounded-[10px] border-[1.5px] border-white/20 flex items-center justify-center text-sidebar-gray-1 font-display font-bold text-[12.5px]">00</div>
        <div class="w-[40px] h-[40px] rounded-[10px] bg-brand-red text-white flex items-center justify-center font-display font-bold text-[12.5px] shadow-[0_0_0_4px_rgba(192,80,77,0.22)]">01</div>
        <div class="w-[40px] h-[40px] rounded-[10px] border-[1.5px] border-white/20 flex items-center justify-center text-sidebar-gray-1 font-display font-bold text-[12.5px]">02</div>
        <div class="w-[40px] h-[40px] rounded-[10px] border-[1.5px] border-white/20 flex items-center justify-center text-sidebar-gray-1 font-display font-bold text-[12.5px]">03</div>
      </div>
    </aside>

    <!-- Canvas -->
    <main class="flex-1 flex flex-col min-w-0 bg-canvas relative">

      <!-- Topbar -->
      <div class="flex items-center gap-[16px] p-[16px_28px] flex-none">
        <button id="toggle-sidebar" class="w-[38px] h-[38px] rounded-[10px] bg-white border border-border-light cursor-pointer flex items-center justify-center text-brand-blue flex-none hover:border-brand-blue transition-colors">
          <span id="toggle-icon" class="font-display font-bold text-[16px] leading-none">⟨</span>
        </button>
        <div class="flex items-center gap-[9px] font-display font-semibold text-[13px]">
          <span class="text-brand-blue">{moduleName}</span>
          <span class="text-[#c4cbd6]">/</span>
          <span class="text-ink-secondary">{themeName}</span>
        </div>
        <div class="ml-auto flex items-baseline gap-[6px] font-display">
          <span class="font-bold text-[18px] text-brand-blue">{numStr}</span>
          <span class="font-normal text-[13px] text-[#9aa3b2]">/ {totalStr}</span>
        </div>
      </div>

      <!-- Slide Stage -->
      <div class="flex-1 flex items-center justify-center p-[4px_28px] overflow-hidden min-h-0">
        <div class="w-full max-w-[calc((100vh-168px)*1.6)]">
          <slot />
        </div>
      </div>

      <!-- Controls -->
      <div class="flex-none flex items-center justify-center gap-[22px] p-[16px_28px_22px]">
        {prevUrl ? (
          <a href={prevUrl} class="w-[46px] h-[46px] rounded-full bg-white border border-border-light flex items-center justify-center text-brand-blue font-bold text-[19px] hover:border-brand-blue transition-colors no-underline">←</a>
        ) : (
          <div class="w-[46px] h-[46px] rounded-full border border-border-light flex items-center justify-center text-gray-300 font-bold text-[19px] opacity-50 cursor-not-allowed">←</div>
        )}
        
        <div class="flex items-center gap-[10px]">
          {Array.from({ length: totalSlides }).map((_, i) => {
            const isCurrent = i + 1 === currentSlideNum;
            return (
              <a 
                href={`/estrategia/${i + 1}`}
                class={`h-[9px] rounded-[6px] transition-all duration-250 ${isCurrent ? 'w-[34px] bg-brand-red' : 'w-[9px] bg-[#c4cbd6] hover:bg-[#a0aabf]'}`}
              ></a>
            );
          })}
        </div>

        {nextUrl ? (
          <a href={nextUrl} class="w-[46px] h-[46px] rounded-full bg-brand-blue border border-brand-blue flex items-center justify-center text-white font-bold text-[19px] hover:bg-brand-sidebar transition-colors no-underline">→</a>
        ) : (
          <div class="w-[46px] h-[46px] rounded-full bg-gray-300 flex items-center justify-center text-white font-bold text-[19px] opacity-50 cursor-not-allowed">→</div>
        )}
      </div>

    </main>
  </div>

  <script>
    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') {
        const nextBtn = document.querySelector('a[href].bg-brand-blue');
        if (nextBtn) (nextBtn as HTMLAnchorElement).click();
      } else if (e.key === 'ArrowLeft') {
        const prevBtn = document.querySelector('a[href].bg-white.text-brand-blue');
        if (prevBtn) (prevBtn as HTMLAnchorElement).click();
      }
    });

    // Sidebar toggle logic
    const toggleBtn = document.getElementById('toggle-sidebar');
    const sidebar = document.getElementById('sidebar');
    const expanded = document.getElementById('sidebar-expanded');
    const collapsed = document.getElementById('sidebar-collapsed');
    const toggleIcon = document.getElementById('toggle-icon');
    
    let isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';

    function applyState() {
      if (!sidebar || !expanded || !collapsed || !toggleIcon) return;
      if (isCollapsed) {
        sidebar.style.width = '78px';
        expanded.classList.add('hidden');
        collapsed.classList.remove('hidden');
        toggleIcon.textContent = '☰';
      } else {
        sidebar.style.width = '280px';
        expanded.classList.remove('hidden');
        collapsed.classList.add('hidden');
        toggleIcon.textContent = '⟨';
      }
    }

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        isCollapsed = !isCollapsed;
        localStorage.setItem('sidebarCollapsed', isCollapsed.toString());
        applyState();
      });
    }

    // Apply initial state
    applyState();
  </script>
</body>
</html>
