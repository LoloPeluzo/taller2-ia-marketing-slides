---
import '../styles/global.css';

const { frontmatter } = Astro.props;

const title = frontmatter?.title || "Diapositiva";
const subtitle = frontmatter?.subtitle || "";
const modulo = frontmatter?.modulo || "";
const accent = frontmatter?.accent || "blue";

// Map colors
const accentColor = accent === 'blue' ? '#114a90' : accent === 'purple' ? '#7e22ce' : '#C0504D';
const bgAccentClass = accent === 'blue' ? 'bg-[#114a90]' : accent === 'purple' ? 'bg-[#7e22ce]' : 'bg-[#C0504D]';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #f3f4f6;
      color: #333;
    }
    .markdown-content h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #114a90;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }
    .markdown-content h3 {
      font-size: 1.25rem;
      font-weight: 600;
      color: #374151;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .markdown-content p {
      margin-bottom: 1rem;
      line-height: 1.7;
    }
    .markdown-content ul, .markdown-content ol {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
    }
    .markdown-content li {
      margin-bottom: 0.5rem;
      line-height: 1.7;
    }
    .markdown-content ul {
      list-style-type: disc;
    }
    .markdown-content strong {
      font-weight: 600;
      color: #111827;
    }
    .markdown-content blockquote {
      border-left: 4px solid #C0504D;
      padding-left: 1rem;
      color: #4B5563;
      font-style: italic;
      background-color: #f9fafb;
      padding: 1rem;
      border-radius: 0 0.5rem 0.5rem 0;
      margin: 1.5rem 0;
    }
    .markdown-content pre {
      background-color: #1f2937;
      color: #e5e7eb;
      padding: 1rem;
      border-radius: 0.5rem;
      overflow-x: auto;
      margin-bottom: 1rem;
    }
    .markdown-content code {
      background-color: #e5e7eb;
      padding: 0.2rem 0.4rem;
      border-radius: 0.25rem;
      font-size: 0.875em;
      color: #b91c1c;
    }
    .markdown-content pre code {
      background-color: transparent;
      color: inherit;
      padding: 0;
    }
    .markdown-content table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
    }
    .markdown-content th, .markdown-content td {
      border: 1px solid #d1d5db;
      padding: 0.75rem;
      text-align: left;
    }
    .markdown-content th {
      background-color: #f3f4f6;
      font-weight: 600;
    }
  </style>
</head>
<body class="min-h-screen flex flex-col items-center py-10 px-4">

  <!-- Contenedor estilo diapositiva -->
  <main class="w-full max-w-4xl bg-white rounded-xl shadow-xl overflow-hidden relative">
    
    <!-- Barra superior de acento -->
    <div class={`w-full h-3 ${bgAccentClass}`}></div>
    
    <!-- Cabecera -->
    <header class="px-10 py-8 border-b border-gray-100 flex justify-between items-start">
      <div>
        {modulo && (
          <div class="flex items-center gap-2 mb-2">
            <div class={`w-6 h-1 ${bgAccentClass}`}></div>
            <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">{modulo}</span>
          </div>
        )}
        <h1 class="text-4xl font-bold" style={`color: ${accentColor}`}>{title}</h1>
        {subtitle && <p class="text-lg text-gray-500 mt-2 font-light">{subtitle}</p>}
      </div>
    </header>

    <!-- Contenido -->
    <article class="px-10 py-8 markdown-content">
      <slot />
    </article>
    
    <!-- Footer con enlace a inicio -->
    <footer class="px-10 py-6 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
      <a href="/" class="text-sm font-medium text-gray-500 hover:text-[#114a90] transition-colors">← Volver al índice</a>
      {frontmatter?.recurso && (
        <a href={frontmatter.recurso} class="text-sm px-4 py-2 bg-[#114a90] text-white rounded-md hover:bg-[#0c3566] transition-colors">
          {frontmatter.recursoLabel || "Ver recurso"}
        </a>
      )}
    </footer>
  </main>

</body>
</html>
