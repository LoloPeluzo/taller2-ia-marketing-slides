---
import SlideLayout from '../../layouts/SlideLayout.astro';

export async function getStaticPaths() {
  const pasos = await import.meta.glob('../../content/pasos/*.md', { eager: true });
  return Object.values(pasos).map((paso: any) => {
    // extract filename without extension for slug
    const slug = paso.file.split('/').pop().split('.').shift();
    return {
      params: { slug },
      props: { paso }
    };
  });
}

const { paso } = Astro.props;
const { Content, frontmatter } = paso;
---

<SlideLayout frontmatter={frontmatter}>
  <Content />
</SlideLayout>
