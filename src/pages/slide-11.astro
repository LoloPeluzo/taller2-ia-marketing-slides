<script>
        const ctx = document.getElementById('pillarChart').getContext('2d');
        const pillarChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Platos estrella', 'Detrás de cámaras', 'Clientes felices', 'Tips culinarios', 'Promociones'],
                datasets: [{
                    data: [30, 25, 20, 15, 10],
                    backgroundColor: [
                        '#114a90',
                        '#60a5fa',
                        '#C0504D',
                        '#fca5a5',
                        '#9ca3af'
                    ],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.9)',
                        titleColor: '#1f2937',
                        bodyColor: '#1f2937',
                        bodyFont: {
                            family: 'Poppins',
                            size: 14
                        },
                        borderColor: '#e5e7eb',
                        borderWidth: 1,
                        padding: 10,
                        displayColors: true,
                        callbacks: {
                            label: function(context) {
                                return ' ' + context.label + ': ' + context.raw + '%';
                            }
                        }
                    }
                },
                animation: {
                    animateScale: true,
                    animateRotate: true
                }
            }
        });
