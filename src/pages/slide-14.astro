</div>
</div>
<div class="col-objective">
<div class="flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-corporate-red"></span>
<p class="text-gray-700 font-medium">Ventas</p>
</div>
</div>
<div class="col-best">
<p class="text-gray-600 bg-gray-50 px-3 py-1 rounded-md inline-block border border-gray-100">
<i class="fa-solid fa-cart-shopping text-xs mr-2 text-gray-400"></i>Conversiones
                        </p>
</div>
</div>
<div class="table-row-card flex w-full bg-white border border-gray-100 rounded-lg p-5 shadow-sm items-center hover:border-l-purple-400 group">
<div class="col-type flex items-center gap-4">
<div class="w-12 h-12 rounded-full bg-purple-50 flex items-center justify-center text-purple-600 text-xl group-hover:bg-purple-500 group-hover:text-white transition-colors">
<i class="fa-solid fa-book-open-reader"></i>
</div>
<div>
<p class="font-bold text-gray-800 text-lg">Storytelling</p>
<p class="text-xs text-gray-400">Historias / Origen</p>
</div>
</div>
<div class="col-objective">
<div class="flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-purple-400"></span>
<p class="text-gray-700 font-medium">Conexión</p>
</div>
</div>
<div class="col-best">
<p class="text-gray-600 bg-gray-50 px-3 py-1 rounded-md inline-block border border-gray-100">
<i class="fa-solid fa-heart text-xs mr-2 text-gray-400"></i>Brand Building
                        </p>
</div>
</div>
</div>
<div class="absolute right-10 bottom-20 w-32 h-32 bg-corporate-blue opacity-5 rounded-full blur-2xl -z-10"></div>
<div class="absolute left-10 top-40 w-40 h-40 bg-corporate-red opacity-5 rounded-full blur-2xl -z-10"></div>
