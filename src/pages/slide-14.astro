        <span style="padding: 10px 15px; background: #fff; color: #333; border-radius: 5px; border: 1px solid #ccc;">14 / 26</span>
        <a href="/slide-15" style="padding: 10px 15px; background: #114a90; color: #fff; text-decoration: none; border-radius: 5px; opacity: 1; pointer-events: auto">Siguiente</a>
    </div>
    
