<div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-500 text-xl group-hover:bg-blue-500 group-hover:text-white transition-colors">
<i class="fa-solid fa-comments"></i>
</div>
<div>
