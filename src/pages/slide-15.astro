<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
<style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f3f4f6;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .slide-container {
            width: 1024px;
            height: 768px;
            background-color: #ffffff;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }
        .font-poppins {
            font-family: 'Poppins', sans-serif;
        }
        .text-corporate-blue {
            color: #114a90;
        }
        .bg-corporate-blue {
            background-color: #114a90;
        }
        .text-corporate-red {
            color: #C0504D;
        }
        .bg-corporate-red {
            background-color: #C0504D;
        }
        .border-corporate-red {
            border-color: #C0504D;
        }
        .border-corporate-blue {
            border-color: #114a90;
        }
        
        .gem-button {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .gem-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(192, 80, 77, 0.3);
        }

        /* Post Component Visuals */
        .post-component {
            position: relative;
            padding-left: 24px;
        }
        .post-component::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            border-radius: 2px;
        }
        .pc-hook::before { background-color: #C0504D; }
        .pc-body::before { background-color: #e5e7eb; }
        .pc-cta::before { background-color: #114a90; }
        .pc-tags::before { background-color: #9ca3af; }
    </style>
</head>
