<style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f3f4f6;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .slide-container {
            width: 1024px;
            height: 768px;
            background-color: #ffffff;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }
        .font-poppins {
            font-family: 'Poppins', sans-serif;
        }
        .text-corporate-blue {
            color: #114a90;
        }
        .bg-corporate-blue {
            background-color: #114a90;
        }
        .text-corporate-red {
            color: #C0504D;
        }
