<style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f3f4f6;
            overflow: hidden;
        }
        .slide-container {
            width: 1024px;
            height: 768px;
            background-color: #ffffff;
            position: relative;
            overflow: hidden;
            font-family: 'Poppins', sans-serif;
        }
        .text-corporate-blue { color: #114a90; }
        .bg-corporate-blue { background-color: #114a90; }
        .text-corporate-red { color: #C0504D; }
        .bg-corporate-red { background-color: #C0504D; }
        .border-corporate-red { border-color: #C0504D; }
        .border-corporate-blue { border-color: #114a90; }
        .phone-mockup {
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            transition: transform 0.3s ease;
        }
        .phone-mockup:hover { transform: translateY(-5px); }
        .analysis-card { transition: all 0.3s ease; position: relative; }
        .analysis-card::before {
            content: ''; position: absolute; left: -20px; top: 50%; transform: translateY(-50%);
            width: 20px; height: 2px; background-color: #e5e7eb; z-index: 0;
        }
        .analysis-card.hook::before { background-color: #FECACA; }
        .analysis-card.cta::before { background-color: #BFDBFE; }
        .highlight-red {
            background-color: rgba(192, 80, 77, 0.1); color: #C0504D;
            padding: 2px 4px; border-radius: 4px; font-weight: 600;
        }
        .highlight-blue {
            background-color: rgba(17, 74, 144, 0.1); color: #114a90;
            padding: 2px 4px; border-radius: 4px; font-weight: 600;
        }
    </style>
</head>
