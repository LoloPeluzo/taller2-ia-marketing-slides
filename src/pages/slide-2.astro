<!DOCTYPE html>

<html data-theme="light" lang="es" style=""><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Slide 1 - Portada</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700&amp;family=Open+Sans:wght@600&amp;family=Arial&amp;display=swap" rel="stylesheet">
<style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f3f4f6;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .slide-container {
            width: 1024px;
            height: 768px;
            background-color: #ffffff;
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        /* Header Elements */
        .header-top-bar {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: auto;
            max-height: 55px; /* Scaled slightly for 1024 */
            object-fit: cover;
            z-index: 10;
        }

        .header-logos {
            position: absolute;
            top: 60px;
            left: 14px;
            width: 960px; /* Scaled width */
            height: auto;
            z-index: 10;
            object-fit: contain;
        }

        /* Main Content Layout */
        .main-content {
            position: absolute;
            top: 160px; /* Adjusted for 768 height */
            left: 35px;
            width: 954px;
            height: 550px;
            display: flex;
        }

        .left-column {
            display: flex;
            flex-direction: column;
            width: 500px;
            z-index: 20;
        }

        .logos-row {
            display: flex;
            flex-direction: row;
            align-items: center; /* Align items vertically centered in the row */
        }

        .logo-acelera {
            width: 230px; /* Scaled */
            height: auto;
            margin-left: 8px;
            z-index: 203;
        }

        /* New class for the replaced image */
        .logo-colegio {
            width: auto;
            height: 92px; /* Matching the height of the previous element */
            max-width: 160px; /* Constraints to keep layout intact */
            margin-left: 28px;
            margin-top: 8px;
            object-fit: contain;
            z-index: 203;
        }

        .red-separator {
            width: 96px;
            height: 0;
            border-top: 4px solid #C0504D;
            margin-top: 60px; 
            margin-left: 5px;
        }

        .slide-title {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 60px; /* Adjusted size */
            color: #114a90;
            line-height: 1.1;
            margin-top: 20px;
            margin-bottom: 0;
            z-index: 200;
        }

        .presenter-name {
            font-family: 'Poppins', sans-serif;
            font-size: 24px;
            color: #555;
            margin-top: 15px;
            margin-left: 5px;
            font-weight: 400;
        }
        
        .presenter-name p {
            margin: 0;
        }

        .right-illustration {
            position: absolute;
            left: 480px; 
            top: 20px;
            width: 480px; /* Scaled */
            height: auto;
            max-height: 480px;
            z-index: 10;
            object-fit: contain;
        }

        /* Footer Elements */
        .footer-date {
            position: absolute;
            left: 50px;
            bottom: 30px;
            font-family: Arial, sans-serif;
            font-size: 20px;
            color: #000;
            white-space: nowrap;
        }

        .footer-page {
            position: absolute;
            right: 50px;
            bottom: 30px;
            font-family: Arial, sans-serif;
            font-size: 20px;
            color: #000;
            white-space: nowrap;
        }

</style>
</head>
<body style="">
<div class="slide-container">
<!-- Header Images -->
<img alt="Header Bar" class="header-top-bar" src="https://page.gensparksite.com/slides_images/60a56c1f46831e8e40e2de563025f267.png" data-height-listener-added="true">
<img alt="Logos Bar" class="header-logos" src="https://page.gensparksite.com/slides_images/e1012bd8875f19a7696d8d52024c4986.png" data-height-listener-added="true">
<!-- Main Content Area -->
<div class="main-content">
<div class="left-column">
<div class="logos-row">
<img alt="Acelera Pyme Logo" class="logo-acelera" src="https://page.gensparksite.com/slides_images/7efce2f159b9c86d9209605538385c5c.png" data-height-listener-added="true">
<!-- Replaced Text Element with Image -->
<img alt="Colegio Oficial de Ingenieros Industriales Andalucía Occidental" class="logo-colegio" src="https://www.genspark.ai/api/files/s/cDeHrWXM" data-height-listener-added="true">
</div>
<!-- Red Separator Line -->
<div class="red-separator"></div>
<!-- Title -->
<h1 class="slide-title">Estrategias y Marketing Digital en&nbsp; Redes Sociales</h1><p><br></p>
<!-- Presenter Name -->
<div class="presenter-name">
<p>Lolo González</p>
</div>
</div>
<!-- Right Illustration -->
<img alt="Team Illustration" class="right-illustration" src="https://page.gensparksite.com/slides_images/1f6510bfe3622e9410c7dc467442f476.png" data-height-listener-added="true">
</div>
</div>


