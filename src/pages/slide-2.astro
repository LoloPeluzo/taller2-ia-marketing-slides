        <a href="/slide-1" style="padding: 10px 15px; background: #114a90; color: #fff; text-decoration: none; border-radius: 5px; opacity: 1; pointer-events: auto">Anterior</a>
        <span style="padding: 10px 15px; background: #fff; color: #333; border-radius: 5px; border: 1px solid #ccc;">2 / 26</span>
        <a href="/slide-3" style="padding: 10px 15px; background: #114a90; color: #fff; text-decoration: none; border-radius: 5px; opacity: 1; pointer-events: auto">Siguiente</a>
    </div>
    
</body></html>

